# Copy to .env and fill in values for local development.

# Required — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5433/mathassistant

# Optional — local dev uses create_all() when ENVIRONMENT=development or URL is localhost
ENVIRONMENT=development

# Optional — force create_all() instead of Alembic locally (true/1/yes)
# SKIP_MIGRATIONS=true

# Auth (required for production; dev default is insecure placeholder)
# JWT_SECRET=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=60

# Optional — error tracking (leave unset to disable)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
