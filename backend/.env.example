# Copy to .env and fill in values for local development.

# Required â€” PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5433/mathassistant

# Optional â€” local dev uses create_all() when ENVIRONMENT=development or URL is localhost
ENVIRONMENT=development

# Optional â€” force create_all() instead of Alembic locally (true/1/yes)
# SKIP_MIGRATIONS=true

# Auth (JWT_SECRET required in production on Render — never use the dev default)
# JWT_SECRET=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=60

# CORS — comma-separated frontend origins (no trailing slashes)
# CORS_ORIGINS=https://mathassistant-frontend.onrender.com

# Rate limiting (true by default; set false for local load testing)
# RATE_LIMIT_ENABLED=true

# Optional — error tracking (leave unset to disable)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
